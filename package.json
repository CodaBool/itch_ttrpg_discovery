{
  "name": "itch_ttrpg_discovery",
  "scripts": {
    "start": "vite --host",
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "local": "node --env-file=../.env scripts/local.mjs",
    "detail": "node --env-file=../.env scripts/detail.mjs",
    "wipe": "node --env-file=../.env scripts/wipe.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:dev-email": "wrangler dev --config worker/email/wrangler.toml",
    "worker:deploy-email": "wrangler deploy --config worker/email/wrangler.toml",
    "worker:dev-detail": "wrangler dev --config worker/detail/wrangler.toml --remote",
    "worker:deploy-frontend": "wrangler deploy --config wrangler.frontend.toml",
    "worker:d1:migrate": "wrangler d1 migrations apply itch-rpg-feed --remote",
    "worker:d1:migrate:local": "wrangler d1 migrations apply itch-rpg-feed"
  },
  "type": "module",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vite-plugin-svgr": "^5.2.0",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "cld": "^2.10.1",
    "fast-xml-parser": "^5.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
